# ISSO 51 API Configuration
PORT=3001
DATABASE_URL=sqlite://isso51.db?mode=rwc

# OIDC Configuration (optional, leave empty for development without auth)
OIDC_ISSUER=https://auth.open-aec.com/application/o/warmteverlies/
OIDC_AUDIENCE=warmteverlies

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:1420

# OpenAEC Reports — rapportgeneratie proxy
# REPORTS_API_URL is verplicht, REPORTS_API_KEY is optioneel (Bearer token via OIDC is primair)
REPORTS_API_URL=https://report.open-aec.com
REPORTS_API_KEY=
